# Copy to .env.local for local dev, and set the same in your Vercel project.
#
# Canonical production URL (no trailing slash). Drives canonical tags,
# OpenGraph URLs, sitemap, robots, and JSON-LD. Falls back to
# https://ibnads.com if unset (see src/lib/site.ts).
NEXT_PUBLIC_SITE_URL=https://ibnads.com
